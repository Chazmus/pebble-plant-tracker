{
  "name": "pebble-plant-tracker",
  "author": "Chazmus inc.",
  "version": "1.0.3",
  "keywords": ["pebble-app"],
  "private": true,
  "scripts": {
    "build-config": "node build_config.js",
    "build": "pebble build",
    "deploy": "./deploy.sh"
  },
  "dependencies": {},
  "pebble": {
    "displayName": "Plant Tracker",
    "uuid": "38b74051-5193-4ca5-b1c0-e70fd94043b9",
    "projectType": "moddable",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "emery",
      "gabbro"
    ],
    "watchapp": {
      "watchface": false
    },
    "capabilities": [
      "configurable"
    ],
    "messageKeys": [
      "AppKeySync",
      "AppKeyPlantCount",
      "AppKeyPlantIndex",
      "AppKeyPlantId",
      "AppKeyPlantName",
      "AppKeyPlantDate",
      "AppKeyLogType",
      "AppKeyLogAmount",
      "AppKeyLogTime",
      "AppKeyLastWatered",
      "AppKeyLastFertilized",
      "AppKeyLastFertilisedAmount",
      "AppKeyPlantHistory"
    ],
    "resources": {
      "media": []
    }
  }
}
